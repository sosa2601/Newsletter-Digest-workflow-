    {
      "parameters": {
        "jsCode": "function decodeBase64(str) {\n  try {\n    return Buffer.from(str.replace(/-/g,'+').replace(/_/g,'/'), 'base64').toString('utf-8');\n  } catch(e) { return ''; }\n}\n\nfunction findParts(parts, mimeType) {\n  let out = [];\n  if (!parts) return out;\n  for (const p of parts) {\n    if (p.mimeType === mimeType && p.body && p.body.data) {\n      out.push(decodeBase64(p.body.data));\n    }\n    if (p.parts) out = out.concat(findParts(p.parts, mimeType));\n  }\n  return out;\n}\n\nconst SKIP = ['UNREAD','INBOX','SENT','DRAFT','TRASH','SPAM','STARRED','IMPORTANT',\n  'CATEGORY_UPDATES','CATEGORY_PROMOTIONS','CATEGORY_SOCIAL','CATEGORY_FORUMS','CATEGORY_PERSONAL'];\n\nconst results = [];\nconst seen = new Set();\n\nfor (const item of $input.all()) {\n  const email = item.json;\n  if (!email || !email.id) continue;\n  if (seen.has(email.id)) continue;\n  seen.add(email.id);\n\n  // Gmail returns Subject/From/To as TOP-LEVEL keys (capital first letter)\n  const subject = email.Subject || email.subject || '';\n  const sender  = email.From    || email.from    || '';\n  let   date    = email.Date    || email.date    || '';\n\n  if (!date && email.internalDate) {\n    date = new Date(parseInt(email.internalDate)).toISOString();\n  }\n\n  // Body from payload parts\n  let body = email.text || '';\n\n  if (!body && email.payload) {\n    const pl = email.payload;\n    if (pl.body && pl.body.data) {\n      body = decodeBase64(pl.body.data);\n    }\n    if (!body && pl.parts) {\n      const txt = findParts(pl.parts, 'text/plain');\n      if (txt.length > 0) {\n        body = txt.join(' ');\n      } else {\n        body = findParts(pl.parts, 'text/html').join(' ');\n      }\n    }\n  }\n\n  if (body && body.indexOf('<') > -1) {\n    body = body\n      .replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi, '')\n      .replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, '')\n      .replace(/<[^>]+>/g, ' ')\n      .replace(/&nbsp;/g, ' ')\n      .replace(/&amp;/g, '&')\n      .replace(/\\s+/g, ' ')\n      .trim();\n  }\n\n  if (!body) body = email.snippet || '';\n\n  body = body.replace(/unsubscribe[\\s\\S]{0,300}$/i, '').trim();\n  if (body.length > 8000) {\n    body = body.substring(0, 8000) + '... [truncated]';\n  }\n\n  // labels is [{id, name}] — extract name, skip system labels\n  const labelNames = (email.labels || [])\n    .map(function(l) { return l.name || l.id || l; })\n    .filter(function(n) { return !SKIP.includes(n) && n.indexOf('Label_') !== 0; });\n\n  const sourceChannel = labelNames.join(', ') || 'labeled';\n\n  results.push({ json: {\n    email_id: email.id,\n    date: date,\n    sender: sender,\n    subject: subject,\n    body: body,\n    source_type: 'newsletter',\n    source_channel: sourceChannel,\n    processed: 'false',\n    scraped_at: new Date().toISOString()\n  }});\n}\n\nreturn results;"
      },
