      "name": "Gmail Fetch Labeled Emails Only",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.2,
      "position": [
        1232,
        -144
      ],
      "webhookId": "cff1ef8e-fb19-4dba-8994-56764faefb88",
